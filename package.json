{
  "name": "lanhu-mcp",
  "version": "1.1.0",
  "description": "MCP server for Lanhu design restoration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lanhu-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-runtime-to-dist.mjs",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "restore:loop": "npm run build && node scripts/run-lanhu-loop.mjs",
    "validate:sample": "npm run build && node scripts/validate-sample-restoration.mjs",
    "render:lanhu": "npm run build && node scripts/validate-sample-restoration.mjs",
    "test": "npm run build && node --test tests/*.test.mjs"
  },
  "keywords": [
    "mcp",
    "lanhu",
    "design",
    "sketch"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "jimp": "^1.6.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "scripts"
  ]
}
