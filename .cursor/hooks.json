{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "python .cursor/hooks/inject-subagent-context.py",
        "matcher": "Task",
        "timeout": 30
      }
    ],
    "sessionStart": [
      {
        "command": "python .cursor/hooks/session-start.py",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python .cursor/hooks/inject-workflow-state.py",
        "timeout": 5
      }
    ]
  }
}
